{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foundlab.com.br/schemas/aeir/control-mapping.v1.json",
  "title": "ControlMapping",
  "description": "Evidencia -> controle. NAO declara conformidade. Ver concept.md Secao 14.5 e 18.3.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mappings"],
  "properties": {
    "schema_version": { "const": "aeir.control_mapping.v1" },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["control_id", "framework", "evidence_refs", "test_ref"],
        "properties": {
          "control_id": { "type": "string" },
          "framework": { "type": "string", "description": "ex.: BCB-538-2025, LGPD, PCI-DSS, interno" },
          "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "description": "event_id ou decision_id" } },
          "test_ref": { "type": "string", "description": "referencia ao teste que valida esta evidencia" },
          "exception": { "type": "string", "description": "se presente, controle aparece em secao de excecao" }
        }
      }
    }
  }
}
