{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foundlab.com.br/schemas/aeir/verification-result.v1.json",
  "title": "VerificationResult",
  "description": "Saida determinista do verifier. Ver concept.md Secao 10 e 14.7.",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "root_hash_verified", "signatures_verified", "schema_valid", "decision_ids_recomputed", "merkle_chain_valid", "policy_hashes_resolved", "model_hashes_resolved", "redaction_policy_valid", "report_derivation_valid", "exceptions"],
  "properties": {
    "status": { "type": "string", "enum": ["pass", "fail"] },
    "root_hash_verified": { "type": "boolean" },
    "signatures_verified": { "type": "boolean" },
    "schema_valid": { "type": "boolean" },
    "decision_ids_recomputed": { "type": "boolean" },
    "merkle_chain_valid": { "type": "boolean" },
    "policy_hashes_resolved": { "type": "boolean" },
    "model_hashes_resolved": { "type": "boolean" },
    "redaction_policy_valid": { "type": "boolean" },
    "report_derivation_valid": { "type": "boolean" },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "message"],
        "properties": {
          "code": { "type": "string" },
          "severity": { "type": "string", "enum": ["blocking", "warning", "info"] },
          "evidence_ref": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
